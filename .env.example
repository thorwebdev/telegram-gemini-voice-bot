# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Google AI API Key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-google-api-key

# Public URL where this bot is reachable (for webhook registration)
# e.g. https://your-service-xxxxx.run.app or https://your-ngrok-url.ngrok.io
WEBHOOK_URL=https://your-webhook-url

# Enable voice responses by default (true/false)
VOICE_ENABLED=true
